[36m(TaskRunner pid=3370463)[0m     y = 1 + np.sqrt(2) * np.sin(theta)
[36m(TaskRunner pid=3370463)[0m     ds = np.sqrt(np.sin(theta)**2 + 4 * np.cos(theta)**2)
[36m(TaskRunner pid=3370463)[0m     return y * ds
[36m(TaskRunner pid=3370463)[0m 
[36m(TaskRunner pid=3370463)[0m # Compute the integral
